NODE_ENV=production

# MongoDB Atlas — remplace par ta connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/blog-app?retryWrites=true&w=majority

# JWT — utilise des secrets longs et aléatoires en production
JWT_ACCESS_SECRET=change_this_to_a_long_random_secret
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://<ton-backend>.vercel.app/api/auth/google/callback

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=https://<ton-backend>.vercel.app/api/auth/facebook/callback

# Frontend URL (pour les redirects OAuth)
CLIENT_URL=https://<ton-frontend>.vercel.app

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
